# Copy this file to secrets/.env and fill in real values.
# secrets/.env is gitignored. Never commit real credentials.

# -----------------------------
# Twilio voice credentials
# -----------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# E.164 phone numbers, e.g. +14155552671.
# TWILIO_FROM_NUMBER must be a Twilio number or approved caller ID.
# TWILIO_TO_NUMBER is only used by make_call.py for a direct smoke test.
TWILIO_FROM_NUMBER=+10000000000
TWILIO_TO_NUMBER=+10000000000

# -----------------------------
# Public callback URL
# -----------------------------
# Use your ngrok/Cloudflare Tunnel/hosted HTTPS URL without a trailing slash.
# Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=https://your-public-https-url.example

# -----------------------------
# Sarvam realtime voice + LLM
# -----------------------------
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_BASE_URL=https://api.sarvam.ai

# LLM used for sales-agent replies.
SARVAM_CHAT_MODEL=sarvam-30b

# Streaming STT. Use en-IN for English, hi-IN for Hindi, or another BCP-47 code Sarvam supports.
# Brand-specific campaigns share one deployment: changing language here affects all concurrent calls.
# For India-first retail (e.g. Assam Agro Tea), start with en-IN; switch to hi-IN when your script and leads are Hindi.
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_LANGUAGE=en-IN
SARVAM_STT_MODE=transcribe

# Streaming TTS. The app requests 8 kHz mulaw audio for direct Twilio playback.
# Match TTS language to STT when possible. See Sarvam docs for supported speakers per language.
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_SPEAKER=priya
SARVAM_TTS_PACE=1.05

# Keep replies short for phone calls.
MAX_AGENT_TURN_WORDS=38

# -----------------------------
# Local defaults
# -----------------------------
# Used when normalizing lead phone numbers/timezones.
# For Indian leads, set DEFAULT_PHONE_REGION=IN and DEFAULT_TIMEZONE=Asia/Kolkata.
DEFAULT_PHONE_REGION=US
DEFAULT_TIMEZONE=America/New_York

